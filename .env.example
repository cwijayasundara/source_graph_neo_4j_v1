NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=please-change-me

# Only needed for the legacy Ask-the-Codebase path (llm_query.py); BRD + enrichment use Claude.
GOOGLE_API_KEY=your-google-api-key

# BRD Generator
BRD_OUTPUT_DIR=./brd_output
BRD_MAX_RETRIES=2
BRD_SINGLE_SHOT_TOKEN_BUDGET=800000
BRD_MAX_CLUSTER_DEPTH=4

# COBOL support (ProLeap extractor). Requires a JDK 17 and the built JAR
# (mvn -f tools/cobol-extractor/pom.xml package). Set JAVA_HOME so the extractor can
# find java without it being on PATH (the code uses $JAVA_HOME/bin/java). If neither
# JAVA_HOME nor a working `java` on PATH is available, COBOL is skipped with a warning.
# Leave CCG_COBOL_EXTRACTOR_JAR unset to disable COBOL ingestion. CCG_COBOL_COPYBOOK_DIRS
# is a comma-separated list of copybook dirs for COPY resolution. Format: FIXED | VARIABLE | TANDEM.
JAVA_HOME=
CCG_COBOL_EXTRACTOR_JAR=tools/cobol-extractor/target/ccg-cobol-extractor.jar
CCG_COBOL_COPYBOOK_DIRS=
CCG_COBOL_FORMAT=FIXED

# BRD agent (Claude Agent SDK). Replaces the Gemini BRD path.
ANTHROPIC_API_KEY=sk-ant-...
BRD_AGENT_MAX_TURNS=15                   # per subsystem agent
BRD_MAX_SUBSYSTEMS=12                    # fan-out cap
BRD_MAX_RETRIES=1                        # judge-driven regeneration attempts

# Claude model selection (single source of truth). Per-role overrides win over the
# global; leave overrides blank to use the global. All must be Claude model ids.
CODE_GRAPH_LLM_MODEL=claude-sonnet-4-6     # global default for every LLM path
BRD_AGENT_MODEL=                            # optional: BRD synthesis/judge
ENRICHMENT_MODEL=                           # optional: enrichment (else Haiku)
ASK_MODEL=                                  # optional: ask-the-codebase (else Haiku)
ADVISOR_MODEL=                              # optional: advisor (else Opus)

# Prompt caching is automatic. Set to 1 to request a 1-hour cache TTL (better for
# big batch runs; cache writes cost slightly more). Leave blank for the 5-min default.
CCG_PROMPT_CACHING_1H=

# Advisor strategy: let cheap BRD workers escalate hard calls to an Opus advisor.
BRD_ADVISOR_ENABLED=       # 1 to enable (off by default; adds Opus calls)
ADVISOR_MAX_USES=3         # per-BRD-run advisor call budget (shared across subsystems)
