NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=please-change-me

# Optional: for LLM semantic enrichment
ANTHROPIC_API_KEY=sk-ant-...

# Optional: for Ask the Codebase
GOOGLE_API_KEY=your-google-api-key
CODE_GRAPH_LLM_MODEL=gemini-3.5-flash

# BRD Generator
BRD_MODEL=claude-opus-4-7
BRD_OUTPUT_DIR=./brd_output
BRD_MAX_RETRIES=2
BRD_SINGLE_SHOT_TOKEN_BUDGET=800000
BRD_MAX_CLUSTER_DEPTH=4
