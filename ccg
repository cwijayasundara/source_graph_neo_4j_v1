#!/usr/bin/env bash
# Self-contained launcher for the `ccg` CLI.
#
# Avoids the editable-install (.pth) path entirely — it imports the package
# directly from src/, so it keeps working even if site-packages metadata gets
# clobbered by sync/backup tools that hide .pth files or duplicate them.
#
# Usage: ./ccg <subcommand> [args]    (e.g. ./ccg serve --port 8000)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

export PYTHONPATH="${SCRIPT_DIR}/src${PYTHONPATH:+:${PYTHONPATH}}"
exec uv run --project "$SCRIPT_DIR" python -m code_context_graph "$@"
